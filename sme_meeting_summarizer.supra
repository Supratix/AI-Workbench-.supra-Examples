        "signal_map"
      ],
      "tool_category": "ai_tool",
      "tool": "sme_meeting_summarizer_decision",
      "prompt": "Create a pragmatic owner decision plan for meeting facts, decisions, owners, deadlines, unresolved questions, and follow-up commitments. Include the recommended decision, rejected alternatives, first 72-hour actions, owners, metrics, and review triggers. Keep advice bounded by the provided facts and mark anything that needs finance, legal, safety, or compliance review. Return JSON only.",
      "tooling": {
