{
  "key": "sme_meeting_summarizer",
  "title": "SME Meeting Summarizer",
  "description": "Summarize meeting notes into decisions, actions, risks, owners, due dates, evidence gaps, and follow-up prompts.",
  "workbench_title": "SME Meeting Summarizer Desk",
  "schemaVersion": 1,
  "metadata": {
    "module_name": "sme_meeting_summarizer",
    "vendor": "SupraTix",
