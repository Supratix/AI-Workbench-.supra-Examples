{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/supra-output-contract.schema.json",
  "title": "AI Workbench .supra Output Contract",
  "type": "object",
  "required": [
    "schema_version",
    "content_type",
    "expects_json",
    "required_fields",
    "json_schema",
    "quality_gate",
    "evidence_policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "content_type": {
      "const": "application/json"
    },
    "expects_json": {
      "const": true
    },
    "required_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "json_schema": {
      "type": "object",
      "required": [
        "type",
        "required",
        "properties"
      ],
      "properties": {
        "type": {
          "const": "object"
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "properties": {
          "type": "object",
          "minProperties": 1
        }
      },
      "additionalProperties": true
    },
    "quality_gate": {
      "type": "string",
      "minLength": 1
    },
    "evidence_policy": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
