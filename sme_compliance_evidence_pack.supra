{
  "key": "sme_compliance_evidence_pack",
  "title": "SME Compliance Evidence Pack",
  "description": "Organize compliance facts into an evidence pack with gaps, owners, and reviewer notes.",
  "workbench_title": "SME Compliance Evidence Pack Desk",
  "schemaVersion": 1,
  "metadata": {
    "module_name": "sme_compliance_evidence_pack",
    "vendor": "SupraTix",
    "global_product_pk": "",
    "content_name": "SME Compliance Evidence Pack",
    "content_description": "Organize compliance facts into an evidence pack with gaps, owners, and reviewer notes.",
    "export_version": "1.0.0",
    "import_version": "1.0.0",
    "starter_rows": [
      {
        "title": "SME Compliance Evidence Pack starter",
        "source_type": "business_context",
        "external_urls": [],
        "request": "Paste the source context for SME Compliance Evidence Pack.",
        "text": "{\"schema\":\"DISRUPTIVE_SME_INTAKE_V1\",\"use_case\":\"sme_compliance_evidence_pack\",\"focus\":\"controls, policies, evidence artefacts, missing proof, owner accountability, and human review requirements\",\"intake\":\"Business context: We need a reliable decision support flow for SME Compliance Evidence Pack.\\nCurrent situation: Inputs are incomplete, owners need an answer this week, and leadership wants visible assumptions.\\nKnown constraint: Do not invent facts; mark evidence gaps and human-review items.\",\"guardrails\":[\"Do not invent facts.\",\"Mark assumptions and evidence gaps.\",\"Prefer actions that can be started this week.\",\"Keep financial, legal, safety, and compliance advice reviewable by a responsible human.\"],\"target_outputs\":[\"signal_map\",\"decision_plan\",\"execution_brief\"]}"
      }
    ],
    "commerce": {
      "business_model": "free_of_use",
      "product_typ": "workflows",
      "usage_unit": "cloud_credits",
      "quota": {
        "unit": "cloud_credits"
      }
    },
    "github_example": {
      "repository_layout": "packages at repo root; generated docs under docs/; schemas under schemas/",
      "maintained_for": "AI Workbench .supra examples"
    }
  },
  "columns": [
    {
      "key": "business_context",
      "title": "Business context",
      "column_kind": "step",
      "type": "fa-solid fa-file",
      "type_tool_input_dropdown": "fa-solid fa-file",
      "tool_category": "manual",
      "tool": "user_input",
      "tooling": {
        "prompt_execution": {
          "execute_prompt": false,
