    },
    {
      "key": "signal_map",
      "title": "Signal map",
      "column_kind": "step",
      "type": "fa-solid fa-list-radio",
      "type_tool_input_dropdown": "fa-solid fa-list-radio",
      "input_from": [
        "business_context"
      ],
      "tool_category": "ai_tool",
      "tool": "sme_compliance_evidence_pack_signals",
      "prompt": "Analyze the SME context for controls, policies, evidence artefacts, missing proof, owner accountability, and human review requirements. Extract the most important facts, weak signals, constraints, assumptions, risks, and evidence gaps. Estimate likely impact qualitatively when numbers are missing. Do not invent facts. Return JSON only.",
      "tooling": {
        "prompt_execution": {
          "execute_prompt": true,
          "selected": true,
          "mode": "manual_review",
          "requires_review": true,
          "label": "Map signals",
          "reason": "github_example_package"
        },
        "output_contract": {
          "schema_version": "DISRUPTIVE_SME_WORKBENCH_OUTPUT_V1",
          "content_type": "application/json",
          "expects_json": true,
          "required_fields": [
            "summary",
            "signals",
            "constraints",
            "assumptions",
            "risks",
            "evidence_gaps"
          ],
          "json_schema": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "summary",
              "signals",
              "constraints",
              "assumptions",
              "risks",
              "evidence_gaps"
            ],
            "properties": {
              "summary": {
                "type": "string"
              },
              "signals": {
                "type": "array"
              },
              "constraints": {
                "type": "array"
              },
              "assumptions": {
                "type": "array"
              },
              "risks": {
                "type": "array"
              },
              "evidence_gaps": {
                "type": "array"
              }
            }
          },
          "quality_gate": "Return JSON only. Separate facts from assumptions, identify missing evidence, and recommend concrete next actions.",
          "evidence_policy": "no_invented_facts"
        }
      }
    },
    {
      "key": "decision_plan",
      "title": "Decision plan",
      "column_kind": "step",
      "type": "fa-solid fa-route",
      "type_tool_input_dropdown": "fa-solid fa-route",
      "input_from": [
        "business_context",
        "signal_map"
      ],
      "tool_category": "ai_tool",
      "tool": "sme_compliance_evidence_pack_decision",
      "prompt": "Create a pragmatic owner decision plan for controls, policies, evidence artefacts, missing proof, owner accountability, and human review requirements. Include the recommended decision, rejected alternatives, first 72-hour actions, owners, metrics, and review triggers. Keep advice bounded by the provided facts and mark anything that needs finance, legal, safety, or compliance review. Return JSON only.",
      "tooling": {
